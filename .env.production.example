# Plantilla sin secretos reales. Para un .env ya generado con claves, usá el archivo
# `.env.production` (gitignored) en tu máquina o copiá su contenido al servidor.

USE_SQLITE=false
DJANGO_ENV=production
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=generar_con_openssl_rand_base64_48_o_django_get_random_secret_key
DJANGO_ALLOWED_HOSTS=api.publivalla.com,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://sambil.publivalla.com
CSRF_TRUSTED_ORIGINS=https://sambil.publivalla.com,https://api.publivalla.com

POSTGRES_DB=sambil
POSTGRES_USER=sambil
POSTGRES_PASSWORD=definir_password_seguro
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
